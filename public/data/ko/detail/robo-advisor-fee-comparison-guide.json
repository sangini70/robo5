  "structuredDataJsonLd": "{\n    \"@context\": \"[https://schema.org](https://schema.org)\",\n    \"@type\": \"FAQPage\",\n    \"mainEntity\": [\n        {\n            \"@type\": \"Question\",\n            \"name\": \"손실이 났을 때도 수수료를 내야 하나요?\",\n            \"acceptedAnswer\": {\n                \"@type\": \"Answer\",\n                \"text\": \"기본 운용 수수료 방식은 손실 여부와 상관없이 자산 평가액을 기준으로 부과되며, 성과 수수료 방식은 약관에 명시된 수익 발생 요건을 충족할 때만 부과됩니다.\"\n            }\n        },\n        {\n            \"@type\": \"Question\",\n            \"name\": \"로보어드바이저 수수료 평균은 어느 정도인가요?\",\n            \"acceptedAnswer\": {\n                \"@type\": \"Answer\",\n                \"text\": \"국내 서비스의 경우 연 0.2%에서 0.5% 사이의 운용 보수를 받거나, 수익금의 약 10%에서 15%를 성과 보수로 책정하는 경우가 많습니다.\"\n            }\n        }\n    ]\n}",
